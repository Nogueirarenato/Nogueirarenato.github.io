{
  "name": "urna-eletronica",
  "version": "1.0.0",
  "description": "Urna Eletrônica para Grêmio Estudantil",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.urna.eletronica",
    "productName": "Urna Eletrônica",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!node_modules"
    ],
    "win": {
      "target": "nsis",
      "icon": "icone.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icone.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icone.icns"
    }
  }
}